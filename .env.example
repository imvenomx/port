# =====================================================
# SharpsB2B — environment variables
# Copy this file to `.env` and fill in values. Never commit `.env`.
# =====================================================

# ---- Public site ----------------------------------------------------------
# Used for canonical URLs, sitemap, OG tags, hreflang.
NEXT_PUBLIC_SITE_URL="https://sharpsb2b.com"

# ---- Database -------------------------------------------------------------
# Default: local SQLite file. For production use Postgres (e.g.
# postgres://user:pass@host:5432/db) and update prisma/schema.prisma datasource.
DATABASE_URL="file:./dev.db"

# ---- Auth (dashboard) -----------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Admin login. ADMIN_PASSWORD_HASH must be a bcrypt hash.
# Admin login.
#
# Bcrypt hashes start with `$2b$10$…` — those `$` characters are mangled by the
# Next.js env loader. Use the base64-wrapped variable instead. Generate with:
#
#   node -e "const b=require('bcryptjs'); \
#     console.log(Buffer.from(b.hashSync('your-password', 10)).toString('base64'))"
#
# Paste the resulting one-line base64 string into ADMIN_PASSWORD_HASH_B64.
ADMIN_EMAIL="admin@sharpsb2b.com"
ADMIN_PASSWORD_HASH_B64=""

# ---- OpenRouter (image generation) ----------------------------------------
# Image generation model. If unset or any call fails, the site falls back to
# a placeholder image — builds and requests never break.
OPENROUTER_API_KEY=""
OPENROUTER_IMAGE_MODEL="openai/gpt-5-image"

# ---- Contact form ---------------------------------------------------------
# Provider for the contact form. Leave RESEND_API_KEY empty to stub the
# endpoint (form will return success without sending).
RESEND_API_KEY=""
CONTACT_TO_EMAIL="hello@sharpsb2b.com"
CONTACT_FROM_EMAIL="noreply@sharpsb2b.com"
